// ── Secret admin access (tap logo 5 times) ───────────────────
let secretTapCount=0;
let secretTapTimer=null;
function secretTap(){
  secretTapCount++;
  clearTimeout(secretTapTimer);
  if(secretTapCount>=5){
    secretTapCount=0;
    switchTab('admin');
    showToast('🔐 Admin panel opened');
    return;
  }
  // Visual feedback on logo
  const logo=document.getElementById('secret-tap');
  logo.style.transform='scale(1.3)';
  setTimeout(()=>logo.style.transform='',150);
  // Show subtle hint after 2nd tap
  if(secretTapCount===2) showToast(`Tap ${5-secretTapCount} more times…`);
  secretTapTimer=setTimeout(()=>secretTapCount=0, 1500);
}

